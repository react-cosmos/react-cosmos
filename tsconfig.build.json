{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.fixture.ts",
    "**/*.fixture.tsx",
    "**/__tests__/**/*",
    "**/__fixtures__/**/*",
    "**/testHelpers/**/*",
    "**/testMocks/**/*"
  ]
}
